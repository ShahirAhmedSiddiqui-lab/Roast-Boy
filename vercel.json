{
  "buildCommand": "npm install && mkdir -p public && cp frontend/*.html public/",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/result",
      "destination": "/result.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
